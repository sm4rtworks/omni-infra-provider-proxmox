# Omni Infrastructure Provider settings
# Copy this file to .env and fill in your values.

# Your Omni account API endpoint
OMNI_API_ENDPOINT=https://<account-name>.omni.siderolabs.io/

# Infrastructure provider key (NOT a service account key)
# Generate this in the Omni UI under Infrastructure Providers
OMNI_SERVICE_ACCOUNT_KEY=<your-infra-provider-key>
